                    </div>
                  </div>
                  <div
                    class="relative flex-1 min-w-0"
                  >
                    <div
                      class="absolute -top-7 -end-2 p-4 z-20 select-none pointer-events-none transition-all duration-200 ease-out opacity-0 translate-x-2"
                      data-message-toolbar="true"
                    >
                      <div
                        class="flex items-center fluux-popover rounded-md "
                      >
                        <button
                          aria-label="chat.reactWith"
                          class="px-2 py-1.5 transition-colors text-base hover:bg-fluux-hover "
                        >
                          👍
                        </button>
                        <button
                          aria-label="chat.reactWith"
                          class="px-2 py-1.5 transition-colors text-base hover:bg-fluux-hover "
                        >
                          ❤️
                        </button>
                        <button
                          aria-label="chat.reactWith"
                          class="px-2 py-1.5 transition-colors text-base hover:bg-fluux-hover "
                        >
                          😂
                        </button>
                        <div
                          class="w-px h-5 bg-fluux-hover"
                        />
                        <div
                          class="relative"
                        >
                          <button
                            aria-label="chat.moreReactions"
                            class="p-1.5 transition-colors hover:bg-fluux-hover"
                          >
                            <span
                              data-testid="icon-emoji"
                            >
                              Emoji
                            </span>
                          </button>
                        </div>
                        <div
                          class="inline-flex"
                        >
                          <button
                            aria-label="chat.editMessage"
                            class="p-1.5 transition-colors hover:bg-fluux-hover"
                          >
                            <span
                              data-testid="icon-edit"
                            >
                              Edit
                            </span>
                          </button>
                        </div>
                        <div
                          class="inline-flex"
                        >
                          <button
                            aria-label="chat.forwardMessage"
                            class="p-1.5 transition-colors opacity-50 cursor-not-allowed hover:bg-fluux-hover"
                            disabled=""
                          >
                            <span
                              data-testid="icon-forward"
                            >
