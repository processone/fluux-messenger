.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local
.env.*.local

# Testing
coverage/

test-results/
playwright-report/

# Generated demo videos (large binaries) — root-anchored so scripts/video/ is NOT ignored
/video/

