# Dependencies
# No trailing slash so node_modules symlinks (used in git worktrees) are also ignored.
node_modules

# Build outputs
dist/
# ...but track the committed per-variant icon dist trees (generate.sh output)
!apps/fluux/src-tauri/icons/icon-variants/*/dist/
!apps/fluux/src-tauri/icons/icon-variants/*/dist/**
ts-docs/
*.tsbuildinfo
target/

# Tauri
**/src-tauri/target/
*.app
*.dmg
*.deb
*.AppImage
*.msi

# IDE
.idea/
.vscode/
*.swp
*.swo

